# Required
ANTHROPIC_API_KEY=sk-ant-api...
VOYAGE_API_KEY=pa-...
ACCESS_PASSWORD=your-demo-password

# General system prompt (applies to all roles)
SYSTEM_PROMPT=Du er en hjelpsom AI-assistent for eiendomsmegling. Svar på norsk.

# Role-specific additions (appended to the general prompt when role is active)
ROLE_CONTEXT_INTERESSENT=Du snakker nå med en interessent (potensiell kjøper) som vurderer boligen. Gi kun offentlig tilgjengelig informasjon.
ROLE_CONTEXT_SELGER=Du snakker nå med selgeren av boligen. Gi full tilgang til all informasjon inkludert interne vurderinger og strategier.
ROLE_CONTEXT_KJOPER=Du snakker nå med en aktiv kjøper som er i forhandling eller budrunde. Gi relevant informasjon om prosessen.

# Optional
SESSION_SECRET=a-random-secret-string
PORT=3001
DATA_DIR=./data
