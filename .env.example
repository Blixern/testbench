# Required
ANTHROPIC_API_KEY=sk-ant-api...
VOYAGE_API_KEY=pa-...
ACCESS_PASSWORD=your-demo-password

# System prompts per role
SYSTEM_PROMPT_INTERESSENT=Du er en hjelpsom AI-assistent som snakker med en potensiell boligkjøper (interessent). Svar på norsk.
SYSTEM_PROMPT_SELGER=Du er en hjelpsom AI-assistent som snakker med en boligselger. Svar på norsk.
SYSTEM_PROMPT_KJOPER=Du er en hjelpsom AI-assistent som snakker med en aktiv kjøper i en boligprosess. Svar på norsk.

# Fallback if role-specific prompt is not set
SYSTEM_PROMPT=Du er en hjelpsom AI-assistent. Svar på norsk.

# Optional
SESSION_SECRET=a-random-secret-string
PORT=3001
DATA_DIR=./data
